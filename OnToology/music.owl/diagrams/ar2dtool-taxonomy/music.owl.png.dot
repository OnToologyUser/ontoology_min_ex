digraph ar2dtool_diagram { 
rankdir=LR;
size="1000"
node [shape = rectangle, color="black"]; ":percusion" ":organo" ":teclado" ":pop" ":timbales" ":saxofon" ":genero" ":viento" ":bateria" ":rock" ":guitarra" ":cuerdas" ":sintetizador" ":bajo" ":instrumento" ":trompeta" ; /*classes style*/
